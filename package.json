{
  "name": "lyceum",
  "private": true,
  "version": "1.7.4",
  "author": "Higino-Neto",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mobile": "vite --config vite.mobile.config.ts --host 127.0.0.1",
    "clean:build": "node scripts/clean-build.mjs",
    "size:audit": "node scripts/size-audit.mjs",
    "prebuild": "node scripts/clean-build.mjs",
    "build": "tsc && vite build",
    "build:mobile": "vite build --config vite.mobile.config.ts",
    "mobile:ota": "npm run build:mobile && node scripts/prepare-mobile-ota.mjs",
    "mobile:native-assets": "node scripts/prepare-native-mobile-assets.mjs",
    "cap:sync": "npm run build:mobile && cap sync",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "dist": "npm run build && electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "postinstall": "node scripts/prune-embedpdf-fonts.mjs"
  },
  "build": {
    "appId": "com.higino.lyceum",
    "productName": "Lyceum",
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "pt-BR",
      "en-US"
    ],
    "afterPack": "scripts/electron-after-pack.cjs",
    "asarUnpack": [
      "node_modules/better-sqlite3/build/Release/*.node",
      "node_modules/sharp/**/*.{node,dll}",
      "node_modules/pdf-poppler/lib/win/**"
    ],
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "PDF Document",
        "icon": "pdf-icon"
      },
      {
        "ext": "epub",
        "name": "EPUB Book",
        "description": "EPUB Book",
        "icon": "epub-icon"
      }
    ],
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release",
        "owner": "Higino-Neto",
        "repo": "Lyceum",
        "publishAutoUpdate": true
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "!**/*.map",
      "!**/*.tsbuildinfo",
      "!**/node_modules/**/*.map",
      "!**/node_modules/**/*.md",
      "!**/node_modules/**/{test,tests,__tests__,example,examples,docs,doc}/**",
      "!**/node_modules/pdf-poppler/lib/osx/**",
      "!**/node_modules/better-sqlite3/{deps,src}/**",
      "!**/node_modules/sharp/{src,install}/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capgo/capacitor-updater": "^8.46.1",
    "@supabase/supabase-js": "^2.95.3",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "pdf-poppler": "^0.2.3",
    "pdfjs-dist": "^4.10.38",
    "sharp": "^0.34.5",
    "wink-lemmatizer": "^3.0.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@capgo/cli": "^7.106.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@embedpdf/react-pdf-viewer": "^2.6.2",
    "@radix-ui/react-select": "^2.2.6",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.24",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chokidar": "^1.7.5",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@uiw/react-heat-map": "^2.3.3",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.24",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-icon-builder": "^2.0.1",
    "epubjs": "^0.3.93",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.0.0",
    "lucide-react": "^0.564.0",
    "motion": "^12.38.0",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.0",
    "tailwindcss": "^4.1.18",
    "tar": "^7.5.13",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.4.0",
    "xz-decompress": "^0.2.3"
  },
  "main": "dist-electron/main.js"
}
